      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "primary", "secondary"],
      "minzoom": 10,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 8, 16, 13],
        "symbol-placement": "line",
