      }
    },
    {
      "id": "park-major-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "park_major",
      "minzoom": 4,
      "paint": {
        "line-color": "#6aaa6a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.5, 8, 1, 12, 1.5],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.3, 8, 0.7]
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#a8d8a0",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.4, 8, 0.55, 12, 0.5]
      }
    },
    {
      "id": "park-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "park",
      "minzoom": 5,
      "paint": {
        "line-color": "#6aaa6a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.5, 8, 1, 12, 1.5],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0.4, 8, 0.7]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#aad3df",
        "fill-outline-color": "#9ec7d8"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#aad3df",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 12, 2, 16, 4]
      }
    },
