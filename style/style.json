{
  "version": 8,
  "name": "Austravel Light",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:3000/australia",
      "maxzoom": 14
    },
    "ocean": {
      "type": "vector",
      "url": "http://localhost:3000/ocean",
      "maxzoom": 10
    }
  },
  "glyphs": "http://localhost:3000/font/{fontstack}/{range}",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2efe9"
      }
    },
    {
      "id": "ocean",
      "type": "fill",
      "source": "ocean",
      "source-layer": "ocean",
      "paint": {
        "fill-color": "#aad3df"
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#add19e",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0.6, 14, 0.4]
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#cdebb0",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 14, 0.3]
      }
    },
    {
      "id": "landcover-farmland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "farmland"],
      "paint": {
        "fill-color": "#eef0d5",
        "fill-opacity": 0.5
      }
