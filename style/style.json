    {
      "id": "road-label-motorway",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["all", ["in", "class", "motorway", "trunk"], ["has", "ref"]],
      "minzoom": 8,
      "layout": {
        "text-field": "{ref}",
        "text-font": ["Open Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 9, 14, 12],
        "symbol-placement": "line",
        "text-rotation-alignment": "viewport",
        "symbol-spacing": 400
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 2
      }
    },
    {
      "id": "road-label-primary",
