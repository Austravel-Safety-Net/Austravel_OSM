      "id": "boundary-state",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": {
        "line-color": "#9e9cab",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.5, 10, 1.5],
