      "source-layer": "landcover",
      "filter": ["==", "class", "sand"],
      "paint": {
        "fill-color": "#f5e9c6",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover-wetland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wetland"],
      "paint": {
        "fill-color": "#b8d0bd",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landcover-rock",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "rock"],
      "paint": {
        "fill-color": "#ddd",
        "fill-opacity": 0.3
      }
