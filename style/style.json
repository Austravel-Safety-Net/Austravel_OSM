      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "school", "university", "college", "kindergarten"],
      "minzoom": 11,
      "paint": {
        "fill-color": "#f0e8d8",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landuse-military",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "military"],
